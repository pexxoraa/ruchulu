// ============================================================
// Ruchulu Backend — Prisma Schema (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------

enum Role {
  CUSTOMER
  DELIVERY_PARTNER
  MANAGER
  ADMIN
  SUPER_ADMIN
}

enum ProductType {
  VEG
  NON_VEG
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentMethod {
  COD
  RAZORPAY
  STRIPE
  UPI
  WALLET
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum CouponType {
  PERCENTAGE
  FLAT
  FREE_SHIPPING
}

enum AddressType {
  HOME
  WORK
  OTHER
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
  WHATSAPP
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InventoryMovementType {
  RESTOCK
  SALE
  RETURN
  ADJUSTMENT
  DAMAGE
}

// ---------------------------------------------------------------
// USERS & AUTH
// ---------------------------------------------------------------

model User {
  id                String    @id @default(uuid())
  fullName          String
  email             String    @unique
  phone             String?   @unique
  passwordHash      String
  role              Role      @default(CUSTOMER)
  isEmailVerified   Boolean   @default(false)
  isPhoneVerified   Boolean   @default(false)
  isActive          Boolean   @default(true)
  avatarUrl         String?
  googleId          String?   @unique
  facebookId        String?   @unique
  appleId           String?   @unique
  rewardPoints      Int       @default(0)
  walletBalance     Decimal   @default(0) @db.Decimal(10, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?

  addresses         Address[]
  refreshTokens     RefreshToken[]
  otpCodes          OtpCode[]
  cart              Cart?
  wishlist          WishlistItem[]
  orders            Order[]
  reviews           Review[]
  supportTickets    SupportTicket[]
  notifications     Notification[]
  couponUsages      CouponUsage[]
  recentlyViewed    RecentlyViewed[]
  auditLogs         AuditLog[]
  savedPayments     SavedPayment[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revoked    Boolean  @default(false)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  identifier String  // email or phone the OTP was sent to
  codeHash  String
  purpose   String   // LOGIN | REGISTER | RESET_PASSWORD | VERIFY_PHONE | VERIFY_EMAIL
  expiresAt DateTime
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([identifier, purpose])
  @@map("otp_codes")
}

model Address {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String?
  type         AddressType @default(HOME)
  fullName     String
  phone        String
  line1        String
  line2        String?
  city         String
  state        String
  pincode      String
  country      String      @default("India")
  isDefault    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  orders       Order[]

  @@index([userId])
  @@map("addresses")
}

model SavedPayment {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // razorpay | stripe
  providerRef  String   // tokenised card / method id from provider — never store raw card data
  brand        String?
  last4        String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("saved_payments")
}

// ---------------------------------------------------------------
// CATEGORIES
// ---------------------------------------------------------------

model Category {
  id              String     @id @default(uuid())
  name            String
  slug            String     @unique
  description     String?
  imageUrl        String?
  bannerUrl       String?
  parentId        String?
  parent          Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children        Category[] @relation("CategoryTree")
  metaTitle       String?
  metaDescription String?
  sortOrder       Int        @default(0)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  products        Product[]

  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

// ---------------------------------------------------------------
// PRODUCTS
// ---------------------------------------------------------------

model Product {
  id                  String          @id @default(uuid())
  name                String
  slug                String          @unique
  sku                 String          @unique
  barcode             String?
  categoryId          String
  category            Category        @relation(fields: [categoryId], references: [id])
  type                ProductType     @default(VEG)
  shortDescription    String?
  description         String?
  ingredients         String?
  nutritionInfo       Json?
  shelfLifeDays       Int?
  storageInstructions String?
  spiceLevel          String?         // LOW | MEDIUM | HIGH
  basePrice           Decimal         @db.Decimal(10, 2)
  offerPrice          Decimal?        @db.Decimal(10, 2)
  gstPercent          Decimal         @default(5) @db.Decimal(4, 2)
  status              ProductStatus   @default(DRAFT)
  isFeatured          Boolean         @default(false)
  isTrending          Boolean         @default(false)
  isBestSeller        Boolean         @default(false)
  avgRating           Decimal         @default(0) @db.Decimal(3, 2)
  reviewCount         Int             @default(0)
  totalSold           Int             @default(0)
  metaTitle           String?
  metaDescription     String?
  tags                String[]        @default([])
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  images              ProductImage[]
  variants            ProductVariant[]
  inventory           Inventory[]
  reviews             Review[]
  cartItems           CartItem[]
  orderItems          OrderItem[]
  wishlistItems       WishlistItem[]
  recentlyViewedBy    RecentlyViewed[]
  relatedFrom         ProductRelation[] @relation("RelatedFromProduct")
  relatedTo           ProductRelation[] @relation("RelatedToProduct")

  @@index([categoryId])
  @@index([slug])
  @@index([status])
  @@index([isFeatured])
  @@index([isBestSeller])
  @@map("products")
}

model ProductRelation {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation("RelatedFromProduct", fields: [productId], references: [id], onDelete: Cascade)
  relatedId     String
  related       Product  @relation("RelatedToProduct", fields: [relatedId], references: [id], onDelete: Cascade)
  relationType  String   @default("RELATED") // RELATED | FREQUENTLY_BOUGHT_TOGETHER

  @@unique([productId, relatedId, relationType])
  @@map("product_relations")
}

model ProductImage {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  altText    String?
  isVideo    Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

// A variant represents a purchasable weight option (250g / 500g / 1kg etc.)
model ProductVariant {
  id          String      @id @default(uuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  label       String      // e.g. "250g", "500g", "Gift Box"
  sku         String      @unique
  price       Decimal     @db.Decimal(10, 2)
  offerPrice  Decimal?    @db.Decimal(10, 2)
  weightGrams Int?
  isDefault   Boolean     @default(false)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  inventory   Inventory?
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

// ---------------------------------------------------------------
// INVENTORY
// ---------------------------------------------------------------

model Warehouse {
  id          String       @id @default(uuid())
  name        String
  city        String
  state       String
  pincode     String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())

  inventory   Inventory[]

  @@map("warehouses")
}

model Supplier {
  id          String    @id @default(uuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  createdAt   DateTime  @default(now())

  batches     InventoryBatch[]

  @@map("suppliers")
}

model Inventory {
  id              String      @id @default(uuid())
  productId       String
  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId       String      @unique
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouseId     String
  warehouse       Warehouse   @relation(fields: [warehouseId], references: [id])
  quantity        Int         @default(0)
  reservedQty     Int         @default(0)
  lowStockAlertAt Int         @default(10)
  updatedAt       DateTime    @updatedAt

  batches         InventoryBatch[]
  movements       InventoryMovement[]

  @@index([productId])
  @@index([warehouseId])
  @@map("inventory")
}

model InventoryBatch {
  id           String    @id @default(uuid())
  inventoryId  String
  inventory    Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  batchNumber  String
  quantity     Int
  mfgDate      DateTime?
  expiryDate   DateTime?
  createdAt    DateTime  @default(now())

  @@index([inventoryId])
  @@map("inventory_batches")
}

model InventoryMovement {
  id           String                 @id @default(uuid())
  inventoryId  String
  inventory    Inventory              @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  type         InventoryMovementType
  quantity     Int                    // positive for inbound, negative for outbound
  reason       String?
  referenceId  String?                // e.g. related orderId
  createdAt    DateTime               @default(now())

  @@index([inventoryId])
  @@map("inventory_movements")
}

// ---------------------------------------------------------------
// CART
// ---------------------------------------------------------------

model Cart {
  id         String     @id @default(uuid())
  userId     String?    @unique
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestToken String?    @unique
  couponId   String?
  coupon     Coupon?    @relation(fields: [couponId], references: [id])
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  items      CartItem[]

  @@map("carts")
}

model CartItem {
  id         String         @id @default(uuid())
  cartId     String
  cart       Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String
  product    Product        @relation(fields: [productId], references: [id])
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  quantity   Int            @default(1)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// ---------------------------------------------------------------
// WISHLIST / RECENTLY VIEWED
// ---------------------------------------------------------------

model WishlistItem {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model RecentlyViewed {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  viewedAt   DateTime @default(now())

  @@unique([userId, productId])
  @@map("recently_viewed")
}

// ---------------------------------------------------------------
// ORDERS
// ---------------------------------------------------------------

model Order {
  id              String        @id @default(uuid())
  orderNumber     String        @unique
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  addressId       String
  address         Address       @relation(fields: [addressId], references: [id])
  status          OrderStatus   @default(PENDING)
  subtotal        Decimal       @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  shippingFee     Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  couponId        String?
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  notes           String?
  trackingNumber  String?
  courierName     String?
  estimatedDelivery DateTime?
  cancelReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items           OrderItem[]
  payment         Payment?
  timeline        OrderTimeline[]
  returnRequests  ReturnRequest[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id           String          @id @default(uuid())
  orderId      String
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product         @relation(fields: [productId], references: [id])
  variantId    String
  variant      ProductVariant  @relation(fields: [variantId], references: [id])
  productName  String          // snapshot at time of order
  variantLabel String          // snapshot at time of order
  unitPrice    Decimal         @db.Decimal(10, 2)
  quantity     Int
  totalPrice   Decimal         @db.Decimal(10, 2)

  @@index([orderId])
  @@map("order_items")
}

model OrderTimeline {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId])
  @@map("order_timeline")
}

model ReturnRequest {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason       String
  status       String   @default("REQUESTED") // REQUESTED | APPROVED | REJECTED | REFUNDED
  refundAmount Decimal? @db.Decimal(10, 2)
  isPartial    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orderId])
  @@map("return_requests")
}

// ---------------------------------------------------------------
// PAYMENTS
// ---------------------------------------------------------------

model Payment {
  id              String        @id @default(uuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  provider        String?       // razorpay | stripe
  providerOrderId String?
  providerPaymentId String?
  providerSignature String?
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("INR")
  refundedAmount  Decimal       @default(0) @db.Decimal(10, 2)
  failureReason   String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orderId])
  @@index([providerOrderId])
  @@map("payments")
}

// ---------------------------------------------------------------
// COUPONS
// ---------------------------------------------------------------

model Coupon {
  id                String       @id @default(uuid())
  code              String       @unique
  description       String?
  type              CouponType
  value             Decimal      @db.Decimal(10, 2) // percentage or flat amount
  minOrderAmount    Decimal?     @db.Decimal(10, 2)
  maxDiscountAmount Decimal?     @db.Decimal(10, 2)
  usageLimit        Int?         // total number of times coupon can be used
  usageLimitPerUser Int?         @default(1)
  usedCount         Int          @default(0)
  applicableCategoryIds String[] @default([])
  applicableProductIds  String[] @default([])
  isFestival        Boolean      @default(false)
  isReferral        Boolean      @default(false)
  startsAt          DateTime?
  expiresAt         DateTime?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  usages            CouponUsage[]
  orders            Order[]
  carts             Cart[]

  @@index([code])
  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?
  usedAt    DateTime @default(now())

  @@index([couponId])
  @@index([userId])
  @@map("coupon_usages")
}

// ---------------------------------------------------------------
// REVIEWS
// ---------------------------------------------------------------

model Review {
  id                String   @id @default(uuid())
  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating            Int      // 1-5
  title             String?
  comment           String?
  images            String[] @default([])
  videos            String[] @default([])
  isVerifiedPurchase Boolean @default(false)
  helpfulVotes      Int      @default(0)
  isApproved        Boolean  @default(false)
  adminReply        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@map("reviews")
}

// ---------------------------------------------------------------
// NOTIFICATIONS / SUPPORT / CMS
// ---------------------------------------------------------------

model Notification {
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   NotificationChannel
  title     String
  message   String
  data      Json?
  isRead    Boolean             @default(false)
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId])
  @@map("notifications")
}

model SupportTicket {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  message     String
  status      TicketStatus @default(OPEN)
  orderId     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  replies     TicketReply[]

  @@index([userId])
  @@map("support_tickets")
}

model TicketReply {
  id         String        @id @default(uuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  message    String
  isStaff    Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([ticketId])
  @@map("ticket_replies")
}

model Banner {
  id         String   @id @default(uuid())
  title      String
  imageUrl   String
  linkUrl    String?
  position   String   @default("HOME_HERO")
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime @default(now())

  @@map("banners")
}

model Blog {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  coverImageUrl   String?
  excerpt         String?
  content         String
  authorName      String?
  tags            String[] @default([])
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@map("blogs")
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model NewsletterSubscriber {
  id          String   @id @default(uuid())
  email       String   @unique
  isActive    Boolean  @default(true)
  subscribedAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  isResolved Boolean @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

// ---------------------------------------------------------------
// AUDIT
// ---------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // e.g. "PRODUCT_CREATED", "ORDER_STATUS_UPDATED"
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
